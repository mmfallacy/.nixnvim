{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "default_agent": "ask",
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "webfetch": "allow",
    "doom_loop": "ask",
    "external_directory": "deny",
    "lsp": "allow",
  },
  "lsp": {},
  "agent": {
    // Use explorer agent instead!
    "explore": {
      "disable": true,
    },
  },
  "experimental": {},
}
