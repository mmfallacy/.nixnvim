{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "default_agent": "ask",
  "enabled_providers": ["opencode", "minimax", "xai", "custom-proxy"],
  "provider": "{file:./providers.jsonc}",
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "webfetch": "allow",
    "doom_loop": "ask",
    "external_directory": "deny",
    "lsp": "allow",
  },
  "lsp": {},
  "mcp": "{file:./mcp.jsonc}",
  "agent": {
    // Use explorer agent instead!
    "explore": {
      "disable": true,
    },
  },
  "experimental": {},
}
